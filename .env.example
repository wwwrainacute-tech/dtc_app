# Dare to Care - Local Environment
# --------------------------------

# Vite proxy (only used locally)
VITE_API_URL=http://localhost:3002

# Node environment
NODE_ENV=development

# Database
# For local dev, SQLite is used automatically via server/db.js unless DATABASE_URL is set.
# DATABASE_URL=postgres://user:pass@localhost:5432/dtc

# File Storage
# For local dev, files are saved to server/storage/ unless FILE_STORAGE_PROVIDER is set to netlify-blobs
# FILE_STORAGE_PROVIDER=netlify-blobs

# JWT Auth Secret
JWT_SECRET=local-development-secret-key-12345
