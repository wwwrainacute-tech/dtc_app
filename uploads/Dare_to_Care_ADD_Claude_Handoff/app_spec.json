  "workflows": [
    {
      "name": "Admin: PDF to published template",
      "steps": [
        "Admin opens Upload PDF.",
        "Admin uploads or selects a reference PDF.",
        "System extracts title, sections, field labels, field types, required fields, scoring rules, tables, signatures, and PDF layout hints.",
        "Admin reviews AI interpretation: purpose, audience, record type, cadence, output, autofill fields.",
        "Admin edits field labels/types/options/required flags/scoring/table columns.",
        "Admin saves draft or publishes template.",
        "Published template becomes available to caregiver and visible to office manager records flows.",
        "Audit event is recorded."
      ]
    },
    {
      "name": "Caregiver: Fill and submit form",
      "steps": [
        "Caregiver chooses a form from My day or Available forms.",
        "Caregiver selects a client.",
        "Wizard walks through each section.",
        "Safe autofill can be accepted individually or in bulk; unsafe autofill such as signature requires explicit action.",
        "Required fields block progress until complete.",
        "Computed fields update automatically, such as fall-risk score and tier.",
        "Caregiver reviews answers, previews the branded PDF, signs where required, and submits.",
        "Submission record stores template version, client, values, signer, timestamps, PDF reference, and audit event."
      ]
    },
    {
      "name": "Office Manager: Records review",
      "steps": [
        "Office Manager opens Submissions.",
        "Records can be searched/filtered by client, caregiver, form type, status, and date range.",
        "Manager opens submission detail/PDF, checks completion, requests correction if needed, exports/downloads if authorized.",
        "Manager can monitor required recurring forms such as care plan review, supervisory visit, activity report, and fall-risk reassessment."
      ]
    }
  ],
