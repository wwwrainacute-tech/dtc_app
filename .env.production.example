# Dare to Care - Production Environment (Netlify)
# ----------------------------------------------
# Add these variables to your Netlify Site Settings -> Environment Variables

NODE_ENV=production

# Database (Required for Production)
# E.g., postgres://user:password@hostname:5432/dbname
DATABASE_URL=
DATABASE_PROVIDER=postgres

# File Storage
FILE_STORAGE_PROVIDER=netlify-blobs
PDF_BLOB_STORE=pdfs
UPLOAD_BLOB_STORE=uploads
MAX_UPLOAD_MB=10

# Security (Generate a strong random string!)
JWT_SECRET=

# Seed settings
# Set to 'true' ONLY if you want to wipe and seed the database on the next request.
# VERY DANGEROUS IN PRODUCTION!
SEED_DEMO_DATA=false

# Rate limits
LOGIN_RATE_LIMIT_WINDOW=60000
LOGIN_RATE_LIMIT_MAX=10
